FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock ./
RUN uv sync --no-dev --frozen

COPY src/ ./src/
COPY streamlit_app/dashboard.py ./streamlit_app/dashboard.py

EXPOSE 8501

CMD ["/bin/sh", "-c", "/app/.venv/bin/streamlit run streamlit_app/dashboard.py --server.port ${PORT:-8501} --server.address 0.0.0.0 --server.headless true"]
